#!/bin/zsh
# Claude Code CLI routed to Kimi K3 (kimi.com Kimi-Code, Anthropic-compatible).
# Per https://www.kimi.com/code/docs/en/third-party-tools/other-coding-agents.html
# Own CLAUDE_CONFIG_DIR so the normal Anthropic login/session stays untouched.

load_secret() {
  local file="$1" label="$2" mode mode_value value
  if [[ ! -f "$file" ]]; then
    print -u2 "$label: missing secret file: $file"
    return 1
  fi
  mode="$(stat -f '%Lp' "$file" 2>/dev/null || stat -c '%a' "$file" 2>/dev/null)"
  if [[ -z "$mode" ]]; then
    print -u2 "$label: cannot inspect permissions on $file"
    return 1
  fi
  mode_value=$(( 8#$mode ))
  if (( (mode_value & 8#77) != 0 )); then
    print -u2 "$label: insecure permissions on $file (mode $mode; require 0600 or stricter)"
    return 1
  fi
  IFS= read -r value < "$file" || true
  if [[ -z "${value//[[:space:]]/}" || "$value" == "CHANGE-ME" || "$value" == "YOUR_KEY" ]]; then
    print -u2 "$label: $file is empty or still contains a placeholder"
    return 1
  fi
  REPLY="$value"
}

KIMI_KEY_FILE="$HOME/.config/kimi/api-key"
load_secret "$KIMI_KEY_FILE" claude-kimi || exit 1
KIMI_KEY="$REPLY"

export CLAUDE_CONFIG_DIR="$HOME/.config/claude-kimi"
mkdir -p "$CLAUDE_CONFIG_DIR"
export ANTHROPIC_BASE_URL="https://api.kimi.com/coding/"
export ANTHROPIC_API_KEY="$KIMI_KEY"
export ANTHROPIC_AUTH_TOKEN="$KIMI_KEY"
export ANTHROPIC_MODEL="${KIMI_MODEL:-k3[1m]}"
export ANTHROPIC_SMALL_FAST_MODEL="${KIMI_MODEL:-k3[1m]}"
export CLAUDE_CODE_AUTO_COMPACT_WINDOW=1048576
export CLAUDE_CODE_MAX_CONTEXT_TOKENS=1048576
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# Leaf-worker isolation: `--bare` skips CLAUDE.md auto-discovery, so the global
# ~/.claude/CLAUDE.md orchestrator prompt never leaks into this worker. That leak is
# model-independent (Claude resolves ~/.claude via the system user db, so neither
# CLAUDE_CONFIG_DIR nor HOME suppresses it) and a system-prompt override is not
# reliably honored by weaker models — `--bare` not loading the file is the only
# robust fix. Auth is strictly ANTHROPIC_API_KEY (set above). --bare also drops
# project CLAUDE.md, hooks, and plugins: pass task context in the brief (or
# --add-dir) when needed. Set CLAUDE_WORKER_FULL=1 for a full interactive session.
BARE=(--bare); [[ -n "$CLAUDE_WORKER_FULL" ]] && BARE=()
exec claude "${BARE[@]}" "$@"
