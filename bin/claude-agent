#!/bin/zsh
# claude-agent: role-aware, hang-proof dispatcher over the flat-sub wrappers
# (claude-sol / claude-kimi / claude-minimax).
#
# Usage: claude-agent [--degrade] [--no-isolate] [--include-dirty]
#                     [--allowed-paths GLOBS] [--run-dir DIR] <role> [claude args...]
#        claude-agent runs mark <run-id> integrated|abandoned
#
# Exit: 0 required worker delivered | 3 PRIMARY_UNAVAILABLE (orchestrator re-plans) |
#       4 TASK_FAILED (worker ran, but the task itself failed; no fallback) |
#       10 degraded result (provisional; verify+disclose) | 2 usage error
emulate -L zsh
setopt pipe_fail

PROBE_TIMEOUT=${AGENT_PROBE_TIMEOUT:-25}
TASK_TIMEOUT=${AGENT_TIMEOUT:-1800}
AGENT_BIN_DIR=${AGENT_BIN_DIR:-$HOME/.local/bin}
STATE_ROOT=${WORKJET_STATE_DIR:-$HOME/.local/state/workjet}

mark_run() {
  local run_id="$1" state="$2" index_file run_dir
  [[ -n "$run_id" && "$run_id" != */* && "$run_id" != .* ]] || {
    print -u2 "claude-agent: invalid run id '${run_id:-}'"
    return 2
  }
  case "$state" in
    integrated|abandoned) ;;
    *) print -u2 "claude-agent: mark must be integrated or abandoned"; return 2 ;;
  esac
  index_file="$STATE_ROOT/run-index/$run_id"
  if [[ -f "$index_file" ]]; then
    run_dir="$(<"$index_file")"
  else
    run_dir="$STATE_ROOT/runs/$run_id"
  fi
  [[ -d "$run_dir" ]] || {
    print -u2 "claude-agent: run directory not found for '$run_id': $run_dir"
    return 2
  }
  rm -f "$run_dir/integrated" "$run_dir/abandoned"
  : > "$run_dir/$state"
  print -r -- "[claude-agent] marked run $run_id $state: $run_dir"
}

if [[ "$1" == runs ]]; then
  [[ "$2" == mark && $# -eq 4 ]] || {
    print -u2 "use: claude-agent runs mark <run-id> integrated|abandoned"
    exit 2
  }
  mark_run "$3" "$4"
  exit $?
fi

allow_degrade=0
isolate=1
include_dirty=0
run_dir_override=""
allowed_paths=""
while [[ "$1" == --* ]]; do
  case "$1" in
    --degrade) allow_degrade=1 ;;
    --no-isolate) isolate=0 ;;
    --include-dirty) include_dirty=1 ;;
    --allowed-paths)
      shift
      [[ -n "$1" ]] || { print -u2 "claude-agent: --allowed-paths requires comma-separated globs"; exit 2; }
      allowed_paths="$1"
      ;;
    --allowed-paths=*) allowed_paths="${1#--allowed-paths=}" ;;
    --run-dir)
      shift
      [[ -n "$1" ]] || { print -u2 "claude-agent: --run-dir requires a directory"; exit 2; }
      run_dir_override="$1"
      ;;
    --run-dir=*) run_dir_override="${1#--run-dir=}" ;;
    *) print -u2 "claude-agent: unknown option '$1'"; exit 2 ;;
  esac
  shift
done
role="$1"; shift 2>/dev/null
case "$role" in
  hard) print -u2 "[claude-agent] deprecated role 'hard'; use 'implementation-hard'"; role=implementation-hard ;;
  normal) print -u2 "[claude-agent] deprecated role 'normal'; use 'research'"; role=research ;;
  simple) print -u2 "[claude-agent] deprecated role 'simple'; use 'bulk-generation'"; role=bulk-generation ;;
esac
case "$role" in
  implementation-hard)  chain=(claude-sol claude-kimi claude-opus) ;;
  frontend-greenfield)  chain=(claude-kimi claude-sol claude-opus) ;;
  frontend-integration) chain=(claude-sol claude-kimi claude-opus) ;;
  bulk-generation)      chain=(claude-minimax claude-kimi claude-sol claude-opus) ;;
  review)               chain=(claude-kimi claude-opus) ;;
  research)             chain=(claude-kimi claude-sol claude-minimax claude-opus) ;;
  *)
    print -u2 "claude-agent: unknown role '${role:-}'"
    print -u2 "use: implementation-hard|frontend-greenfield|frontend-integration|bulk-generation|review|research"
    exit 2
    ;;
esac
required_worker=${chain[1]}

unavailable_re='usage limit|out of quota|quota exceeded|quota.*exhaust|membership/subscription|purchase extra usage|upgrade your plan|insufficient (quota|credit|balance)|invalid authentication|invalid api key|authentication_error|unauthorized|401 |403 |429 |rate limit|too many requests|overloaded|connection refused|econnrefused|dial tcp|502 bad gateway|503 service|service unavailable'

is_unavailable() {
  local err="$1" rc="$2"
  (( rc != 0 )) || return 1
  print -r -- "$err" | grep -qiE "$unavailable_re|api error|request failed|fetch failed|network"
}

has_output() { [[ -n "${1//[[:space:]]/}" ]]; }

print_task_failed() {
  local w="$1" err="$2" excerpt
  excerpt="$(print -r -- "$err" | head -n 20 | cut -c1-240)"
  print -u2 "[claude-agent] TASK_FAILED worker=$w (exit 4); no provider fallback was attempted."
  if [[ -n "${excerpt//[[:space:]]/}" ]]; then
    print -u2 "[claude-agent] stderr excerpt:"
    print -u2 -r -- "$excerpt"
  else
    print -u2 "[claude-agent] stderr excerpt: <empty>"
  fi
}

# Start each command in its own session/process group so timeout cleanup reaches children.
run_timed() {
  local secs=$1 of=$2 ef=$3; shift 3
  if (( $+commands[setsid] )); then
    setsid "$@" </dev/null >"$of" 2>"$ef" &
  else
    python3 -c 'import os, sys; os.setsid(); os.execvp(sys.argv[1], sys.argv[1:])' "$@" </dev/null >"$of" 2>"$ef" &
  fi
  local pid=$! timeout_marker="${of}.timeout.$$" watchdog rc
  (
    sleep "$secs"
    if kill -0 $pid 2>/dev/null; then
      : > "$timeout_marker"
      kill -TERM -- -$pid 2>/dev/null
      sleep 1
      kill -KILL -- -$pid 2>/dev/null
    fi
  ) &
  watchdog=$!
  wait $pid 2>/dev/null
  rc=$?
  kill $watchdog 2>/dev/null
  wait $watchdog 2>/dev/null
  if [[ -f "$timeout_marker" ]]; then
    rm -f "$timeout_marker"
    return 124
  fi
  return $rc
}

args=("$@")
task_args=("${args[@]}")
caller_sets_tools=0
for arg in "${args[@]}"; do
  case "$arg" in
    --allowedTools|--allowedTools=*|--tools|--tools=*) caller_sets_tools=1 ;;
  esac
done
if (( ! caller_sets_tools )); then
  case "$role" in
    review)
      task_args+=(--allowedTools "Read,Grep,Glob" --disallowedTools "Write,Edit,Bash")
      ;;
    bulk-generation)
      task_args+=(--allowedTools "Read,Write,Grep,Glob,Bash" --disallowedTools "Edit")
      ;;
    *)
      task_args+=(--allowedTools "Read,Write,Edit,Grep,Glob,Bash")
      ;;
  esac
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
repo_subdir=""
if [[ -n "$repo_root" ]]; then
  repo_root="${repo_root:A}"
  current_dir="${PWD:A}"
  repo_subdir="${current_dir#$repo_root}"
else
  isolate=0
  print -u2 "[claude-agent] warning: current directory is not a Git repository; running in-place"
fi

RUN_WORKER=""
RUN_WORKTREE=""
RUN_GIT_BEFORE=""
RUN_ID=""
REPO_ID=""
WORKTREE_PATH=""
WORKTREE_BASE=""
WORKER_CWD=""
WORKTREE_USE_COUNT=0
FAILED_CHECKPOINT_COUNT=0
ATTEMPT_COUNT=0

sha256_short() {
  if (( $+commands[shasum] )); then
    print -rn -- "$1" | shasum -a 256 | awk '{print substr($1,1,16)}'
  elif (( $+commands[sha256sum] )); then
    print -rn -- "$1" | sha256sum | awk '{print substr($1,1,16)}'
  else
    print -u2 "claude-agent: shasum or sha256sum is required"
    return 2
  fi
}

init_run_dir() {
  local stamp brief="" i raw_id index_tmp
  stamp="$(date +%Y%m%dT%H%M%S)-$$"
  if [[ -n "$run_dir_override" ]]; then
    RUN_DIR="${run_dir_override:A}"
    raw_id="${RUN_DIR:t}-${stamp}"
  else
    raw_id="${stamp}-${role}"
    RUN_DIR="$STATE_ROOT/runs/$raw_id"
  fi
  RUN_ID="${raw_id//[^A-Za-z0-9._-]/_}"
  [[ -n "$RUN_ID" && "$RUN_ID" != .* ]] || RUN_ID="run-$stamp"
  mkdir -p "$RUN_DIR/attempts" "$STATE_ROOT/run-index" || {
    print -u2 "claude-agent: cannot create run directory: $RUN_DIR"
    exit 2
  }
  chmod 700 "$RUN_DIR" 2>/dev/null || true
  index_tmp="$STATE_ROOT/run-index/.${RUN_ID}.$$"
  print -r -- "$RUN_DIR" > "$index_tmp" && mv "$index_tmp" "$STATE_ROOT/run-index/$RUN_ID"
  for (( i=1; i <= ${#args}; i++ )); do
    if [[ "${args[$i]}" == -p ]] && (( i < ${#args} )); then
      brief="${args[$(( i + 1 ))]}"
      break
    fi
  done
  print -rn -- "$brief" > "$RUN_DIR/brief.txt"
  : > "$RUN_DIR/stdout"
  : > "$RUN_DIR/stderr"
  : > "$RUN_DIR/worker"
  : > "$RUN_DIR/worktree-path"
  print -r -- "$RUN_ID" > "$RUN_DIR/run-id"
  if [[ -n "$repo_root" ]]; then
    RUN_GIT_BEFORE="$(git -C "$repo_root" rev-parse HEAD 2>/dev/null)"
    print -r -- "$RUN_GIT_BEFORE" > "$RUN_DIR/git-head-before"
    REPO_ID="$(sha256_short "$repo_root")" || exit 2
    print -r -- "$REPO_ID" > "$RUN_DIR/repo-id"
  fi
}

record_attempt() {
  local worker="$1" out="$2" err="$3" attempt_rc="$4" kind="$5" attempt_dir
  RUN_WORKER="$worker"
  (( ++ATTEMPT_COUNT ))
  attempt_dir="$RUN_DIR/attempts/$(printf '%02d' $ATTEMPT_COUNT)-$worker"
  mkdir -p "$attempt_dir"
  print -r -- "$worker" > "$attempt_dir/worker"
  print -r -- "$kind" > "$attempt_dir/kind"
  print -r -- "$attempt_rc" > "$attempt_dir/rc"
  print -rn -- "$out" > "$attempt_dir/stdout"
  print -rn -- "$err" > "$attempt_dir/stderr"
  print -r -- "$RUN_WORKER" > "$RUN_DIR/worker"
  print -rn -- "$out" > "$RUN_DIR/stdout"
  print -rn -- "$err" > "$RUN_DIR/stderr"
}

path_is_allowed() {
  setopt local_options
  unsetopt bad_pattern
  local changed="$1" pattern
  for pattern in ${(s:,:)allowed_paths}; do
    pattern="$(print -r -- "$pattern" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
    [[ -n "$pattern" && "$changed" == ${~pattern} ]] && return 0
  done
  return 1
}

audit_allowed_paths() {
  [[ -n "$allowed_paths" && -n "$repo_root" ]] || return 0
  local git_target="$repo_root" changed names_file violation_file
  local -A seen
  [[ -n "$RUN_WORKTREE" && -d "$RUN_WORKTREE" ]] && git_target="$RUN_WORKTREE"
  names_file="$(mktemp "${TMPDIR:-/tmp}/workjet-paths.XXXXXX")" || return 0
  violation_file="$RUN_DIR/path-violations.txt"
  git -C "$git_target" diff --name-only -z "$RUN_GIT_BEFORE" -- > "$names_file" 2>/dev/null || true
  git -C "$git_target" ls-files --others --exclude-standard -z >> "$names_file" 2>/dev/null || true
  : > "${violation_file}.tmp"
  while IFS= read -r -d '' changed; do
    [[ -n "${seen[$changed]}" ]] && continue
    seen[$changed]=1
    if ! path_is_allowed "$changed"; then
      print -r -- "$changed" >> "${violation_file}.tmp"
      print -u2 "[claude-agent] PATH_VIOLATION: $changed (allowed: $allowed_paths)"
    fi
  done < "$names_file"
  rm -f "$names_file"
  if [[ -s "${violation_file}.tmp" ]]; then
    mv "${violation_file}.tmp" "$violation_file"
    print -u2 "[claude-agent] path audit flagged changes; see: $violation_file"
  else
    rm -f "${violation_file}.tmp" "$violation_file"
  fi
}

finalize_run() {
  local final_rc="$1" git_target git_after diffstat
  print -r -- "$final_rc" > "$RUN_DIR/rc"
  print -r -- "$RUN_WORKER" > "$RUN_DIR/worker"
  print -r -- "$RUN_WORKTREE" > "$RUN_DIR/worktree-path"
  if [[ -n "$repo_root" ]]; then
    git_target="$repo_root"
    [[ -n "$RUN_WORKTREE" && -d "$RUN_WORKTREE" ]] && git_target="$RUN_WORKTREE"
    git_after="$(git -C "$git_target" rev-parse HEAD 2>/dev/null)"
    print -r -- "$git_after" > "$RUN_DIR/git-head-after"
    diffstat="$(git -C "$git_target" diff --stat "$RUN_GIT_BEFORE" -- 2>/dev/null)"
    print -rn -- "$diffstat" > "$RUN_DIR/diffstat"
  fi
  audit_allowed_paths
  print -u2 "[claude-agent] run directory: $RUN_DIR"
}

init_run_dir
trap 'finalize_run $?' EXIT

capture_dirty_patch() {
  local checkout_status index_file git_dir
  [[ -n "$repo_root" ]] || return 0
  checkout_status="$(git -C "$repo_root" status --porcelain --untracked-files=all)"
  [[ -n "$checkout_status" ]] || return 0
  if (( ! include_dirty )); then
    print -u2 "[claude-agent] main checkout is dirty; refusing to start a worker."
    print -u2 "[claude-agent] commit/stash all staged, unstaged, and untracked changes, or pass --include-dirty to copy them intentionally."
    print -u2 -r -- "$checkout_status"
    return 4
  fi
  index_file="$(mktemp "${TMPDIR:-/tmp}/workjet-index.XXXXXX")" || return 4
  rm -f "$index_file"
  git_dir="$(git -C "$repo_root" rev-parse --git-dir)"
  [[ "$git_dir" == /* ]] || git_dir="$repo_root/$git_dir"
  if [[ -f "$git_dir/index" ]]; then
    cp "$git_dir/index" "$index_file" || { rm -f "$index_file"; return 4; }
  else
    GIT_INDEX_FILE="$index_file" git -C "$repo_root" read-tree HEAD || { rm -f "$index_file"; return 4; }
  fi
  if ! GIT_INDEX_FILE="$index_file" git -C "$repo_root" add -A -- .; then
    rm -f "$index_file"
    print_task_failed "dirty snapshot" "could not stage checkout into a temporary index"
    return 4
  fi
  if ! GIT_INDEX_FILE="$index_file" git -C "$repo_root" diff --cached --binary --full-index HEAD -- > "$RUN_DIR/dirty.patch"; then
    rm -f "$index_file"
    print_task_failed "dirty snapshot" "could not archive dirty checkout patch"
    return 4
  fi
  rm -f "$index_file"
  print -u2 "[claude-agent] archived and included dirty checkout: $RUN_DIR/dirty.patch"
}

capture_dirty_patch || exit 4

run_dir_for_id() {
  local id="$1" index_file="$STATE_ROOT/run-index/$id"
  if [[ -f "$index_file" ]]; then
    print -r -- "$(<"$index_file")"
  else
    print -r -- "$STATE_ROOT/runs/$id"
  fi
}

cleanup_stale_worktrees() {
  [[ -n "$repo_root" ]] || return 0
  local root="$STATE_ROOT/worktrees/$REPO_ID" stale id old_run_dir marker
  [[ -d "$root" ]] || return 0
  while IFS= read -r -d '' stale; do
    id="${stale:t}"
    old_run_dir="$(run_dir_for_id "$id")"
    marker=""
    [[ -f "$old_run_dir/integrated" ]] && marker=integrated
    [[ -f "$old_run_dir/abandoned" ]] && marker=abandoned
    if [[ -n "$marker" ]]; then
      print -u2 "[claude-agent] removing $marker worktree older than 24h: $stale"
      if ! git -C "$repo_root" worktree remove --force "$stale" >/dev/null 2>&1; then
        rm -rf -- "$stale"
      fi
    else
      print -u2 "[claude-agent] retained unmarked worktree older than 24h: $stale"
      print -u2 "[claude-agent] inspect/integrate it, then run: claude-agent runs mark $id integrated"
      print -u2 "[claude-agent] or discard it explicitly with: claude-agent runs mark $id abandoned"
    fi
  done < <(find "$root" -mindepth 1 -maxdepth 1 -type d -mtime +0 -print0 2>/dev/null)
  git -C "$repo_root" worktree prune >/dev/null 2>&1 || true
}

cleanup_stale_worktrees

create_worktree() {
  local root="$STATE_ROOT/worktrees/$REPO_ID"
  WORKTREE_PATH="$root/$RUN_ID"
  WORKTREE_BASE="$(git -C "$repo_root" rev-parse HEAD 2>/dev/null)" || return 4
  mkdir -p "$root"
  if [[ -e "$WORKTREE_PATH" ]]; then
    print_task_failed "worktree setup" "worktree path already exists: $WORKTREE_PATH"
    return 4
  fi
  if ! git -C "$repo_root" worktree add --detach --quiet "$WORKTREE_PATH" "$WORKTREE_BASE"; then
    print_task_failed "worktree setup" "git worktree add failed for $WORKTREE_PATH"
    WORKTREE_PATH=""
    return 4
  fi
  RUN_WORKTREE="$WORKTREE_PATH"
  WORKER_CWD="$WORKTREE_PATH$repo_subdir"
  if [[ ! -d "$WORKER_CWD" ]]; then
    print -u2 "[claude-agent] warning: matching subdirectory absent at HEAD; worker starts at worktree root"
    WORKER_CWD="$WORKTREE_PATH"
  fi
}

checkpoint_failed_attempt() {
  local wt="$1" ref sha
  (( FAILED_CHECKPOINT_COUNT++ ))
  ref="refs/workjet/${RUN_ID}-failed-${FAILED_CHECKPOINT_COUNT}"
  if [[ -n "$(git -C "$wt" status --porcelain --untracked-files=all)" ]]; then
    git -C "$wt" add -A -- . || return 4
    git -C "$wt" -c user.name=workjet -c user.email=workjet@localhost \
      -c commit.gpgsign=false commit --no-verify -q -m "workjet: preserve failed attempt $RUN_ID/$FAILED_CHECKPOINT_COUNT" || return 4
  fi
  sha="$(git -C "$wt" rev-parse HEAD)" || return 4
  git -C "$repo_root" update-ref "$ref" "$sha" || return 4
  print -u2 "[claude-agent] preserved failed attempt before retry: $ref ($sha)"
}

prepare_worktree() {
  if [[ -z "$WORKTREE_PATH" ]]; then
    create_worktree || return 4
  elif (( WORKTREE_USE_COUNT > 0 )); then
    checkpoint_failed_attempt "$WORKTREE_PATH" || {
      print_task_failed "worktree checkpoint" "could not preserve the previous failed attempt"
      return 4
    }
    git -C "$WORKTREE_PATH" reset --hard -q "$WORKTREE_BASE" || return 4
    git -C "$WORKTREE_PATH" clean -fdx -q || return 4
  fi
  if [[ -f "$RUN_DIR/dirty.patch" ]]; then
    git -C "$WORKTREE_PATH" apply --binary "$RUN_DIR/dirty.patch" || {
      print_task_failed "dirty snapshot" "could not apply $RUN_DIR/dirty.patch to $WORKTREE_PATH"
      return 4
    }
  fi
  (( ++WORKTREE_USE_COUNT ))
  return 0
}

protect_successful_worktree() {
  local wt="$1" ref="refs/workjet/$RUN_ID" sha
  if [[ -n "$(git -C "$wt" status --porcelain --untracked-files=all)" ]]; then
    git -C "$wt" add -A -- . || return 4
    git -C "$wt" -c user.name=workjet -c user.email=workjet@localhost \
      -c commit.gpgsign=false commit --no-verify -q -m "workjet: preserve run $RUN_ID" || return 4
  fi
  sha="$(git -C "$wt" rev-parse HEAD)" || return 4
  git -C "$repo_root" update-ref "$ref" "$sha" || return 4
  print -r -- "$ref" > "$RUN_DIR/protected-ref"
  print -r -- "$sha" > "$RUN_DIR/protected-sha"
  print -u2 "[claude-agent] protected successful result: $ref ($sha)"
}

report_worktree() {
  local wt="$1" base="$2" wt_status diffstat
  RUN_WORKTREE="$wt"
  wt_status="$(git -C "$wt" status --short 2>/dev/null | head)"
  diffstat="$(git -C "$wt" diff --stat "$base" -- 2>/dev/null)"
  [[ -z "$diffstat" ]] && diffstat="$(git -C "$wt" diff --stat "$base..HEAD" -- 2>/dev/null)"
  print -u2 "[claude-agent] worktree retained: $wt"
  print -u2 "[claude-agent] worktree status (first 10 lines):"
  print -u2 -r -- "${wt_status:-<clean; result committed on protected ref>}"
  print -u2 "[claude-agent] worktree diffstat:"
  print -u2 -r -- "${diffstat:-<no diff>}"
}

ensure_proxy() {
  [[ "$1" == claude-sol ]] || return 0
  lsof -nP -iTCP:8317 -sTCP:LISTEN >/dev/null 2>&1 && return 0
  print -u2 "[claude-agent] cliproxyapi not listening — starting it (restores the intended worker)"
  brew services start cliproxyapi >/dev/null 2>&1; sleep 3
}

probe_available() {
  local w="$1" of ef rc out err
  ensure_proxy "$w"
  of=$(mktemp); ef=$(mktemp)
  run_timed $PROBE_TIMEOUT "$of" "$ef" "$AGENT_BIN_DIR/$w" -p "Reply with the token: OK"; rc=$?
  out="$(<"$of")"; err="$(<"$ef")"
  record_attempt "$w" "$out" "$err" "$rc" probe
  rm -f "$of" "$ef"
  (( rc == 124 )) && { print -u2 "[claude-agent] $w probe timed out (${PROBE_TIMEOUT}s) — treating as unavailable"; return 1; }
  if (( rc == 0 )); then
    has_output "$out" && return 0
    print -u2 "[claude-agent] $w probe returned empty output — treating as unavailable"
    return 1
  fi
  is_unavailable "$err" "$rc" && return 1
  print_task_failed "$w probe" "$err"
  return 4
}

deliver() {
  local w=$1; shift
  local of ef rc err oldpwd="$PWD" wt="" wt_base=""
  ensure_proxy "$w"
  of=$(mktemp); ef=$(mktemp)
  if (( isolate )); then
    prepare_worktree || { rm -f "$of" "$ef"; return 4; }
    wt="$WORKTREE_PATH"; wt_base="$WORKTREE_BASE"
    cd "$WORKER_CWD" || { rm -f "$of" "$ef"; print_task_failed "$w" "cannot enter worktree $WORKER_CWD"; return 4; }
  fi
  run_timed $TASK_TIMEOUT "$of" "$ef" "$AGENT_BIN_DIR/$w" "$@"; rc=$?
  cd "$oldpwd"
  REPLY="$(<"$of")"; err="$(<"$ef")"
  record_attempt "$w" "$REPLY" "$err" "$rc" task
  rm -f "$of" "$ef"
  if (( rc == 124 )); then
    print -u2 "[claude-agent] $w task exceeded ${TASK_TIMEOUT}s cap — retaining worktree for inspection"
    REPLY=""
    return 1
  fi
  if (( rc == 0 )); then
    if has_output "$REPLY"; then
      if [[ -n "$wt" ]]; then
        protect_successful_worktree "$wt" || {
          print_task_failed "$w" "could not commit and protect successful worktree $wt"
          return 4
        }
        report_worktree "$wt" "$wt_base"
      fi
      return 0
    fi
    print -u2 "[claude-agent] $w task returned empty output — retaining worktree and treating as unavailable"
    return 1
  fi
  is_unavailable "$err" "$rc" && return 1
  print_task_failed "$w" "$err"
  REPLY=""
  return 4
}

degrade_candidate=""

probe_available "$required_worker"
probe_rc=$?
(( probe_rc == 4 )) && exit 4
if (( probe_rc == 0 )); then
  deliver "$required_worker" "${task_args[@]}"
  deliver_rc=$?
  (( deliver_rc == 4 )) && exit 4
  if (( deliver_rc == 0 )); then
    print -u2 "[claude-agent] answered by: $required_worker (required for $role)"
    print -r -- "$REPLY"
    exit 0
  fi
  print -u2 "[claude-agent] $required_worker passed probe but hit a provider failure on the task"
else
  print -u2 "[claude-agent] $required_worker unavailable"
fi

# QUOTA FALLBACK (owner rule): if the required worker is down on quota/auth,
# Claude Opus 4.8 (claude-opus, subscription token) steps in as a SAFE
# substitute for any role — announced loudly, never silently.
if [[ "$required_worker" != "claude-opus" ]] && (( ! allow_degrade )); then
  if probe_available claude-opus; then
    print -u2 "[claude-agent] QUOTA FALLBACK: $required_worker down — claude-opus (Opus 4.8) takes the task"
    deliver claude-opus "${task_args[@]}"
    opus_rc=$?
    if (( opus_rc == 0 )); then
      print -u2 "[claude-agent] answered by: claude-opus (quota fallback for $required_worker)"
      print -r -- "$REPLY"
      exit 0
    fi
    (( opus_rc == 4 )) && exit 4
    print -u2 "[claude-agent] claude-opus fallback also failed — continuing to degrade/refusal path"
  else
    print -u2 "[claude-agent] claude-opus fallback not available (token file? quota?)"
  fi
fi

if (( allow_degrade )); then
  for (( i=2; i <= ${#chain}; i++ )); do
    w=${chain[$i]}
    probe_available "$w"
    probe_rc=$?
    (( probe_rc == 4 )) && exit 4
    if (( probe_rc != 0 )); then
      print -u2 "[claude-agent] degraded candidate $w unavailable — skipping"
      continue
    fi
    [[ -z "$degrade_candidate" ]] && degrade_candidate="$w"
    deliver "$w" "${task_args[@]}"
    deliver_rc=$?
    (( deliver_rc == 4 )) && exit 4
    if (( deliver_rc == 0 )); then
      banner="⚠️⚠️ DEGRADED FALLBACK — role=$role required=$required_worker DELIVERED=$w. This worker does not fully satisfy the requested role. Result is PROVISIONAL: re-scope/verify before trusting, and disclose the substitution to the user."
      print -r -- "$banner"
      print -r -- "----- degraded output below -----"
      print -r -- "$REPLY"
      print -u2 "$banner"
      exit 10
    fi
    print -u2 "[claude-agent] degraded candidate $w hit a provider failure — continuing"
  done
fi

print -u2 "════════════════════════════════════════════════════════════════"
print -u2 "[claude-agent] PRIMARY_UNAVAILABLE  role=$role  required=$required_worker"
if [[ "$role" == review ]]; then
  print -u2 "  Kimi is required for an independent review; there is no automatic review fallback."
  print -u2 "  defer review until Kimi is reachable, and state that deferral explicitly."
elif (( ! allow_degrade )) && (( ${#chain} > 1 )); then
  print -u2 "  Later workers in the role chain were not invoked because they do not fully satisfy '$role'."
  print -u2 "  To accept a provisional substitution explicitly: claude-agent --degrade $role ..."
elif [[ -n "$degrade_candidate" ]]; then
  print -u2 "  Every explicitly allowed degraded candidate also hit a provider failure."
else
  print -u2 "  No worker in the role chain is available."
fi
print -u2 "  ORCHESTRATOR MUST RE-PLAN — do NOT silently swap models. Options:"
print -u2 "    • decompose or re-scope the task for a later worker, then use --degrade deliberately;"
print -u2 "    • wait for the required provider's quota/auth window to recover;"
print -u2 "    • do the work yourself."
if [[ "$required_worker" == claude-sol ]]; then
  print -u2 "  ── Sol (ChatGPT Pro OAuth) note: if this is AUTH (not quota), the token expired."
  print -u2 "     You CANNOT fix it — the browser login is the user's step. TELL THE USER to run:"
  print -u2 "         cliproxyapi -codex-login"
  print -u2 "     Do not attempt the login yourself and do not silently route around it."
fi
print -u2 "  SURFACE this to the user if the required worker stays down across the session."
print -u2 "════════════════════════════════════════════════════════════════"
exit 3
